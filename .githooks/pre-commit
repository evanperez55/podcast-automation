#!/bin/bash
# Pre-commit hook: lint, format, and test
# Install: git config core.hooksPath .githooks

set -e

echo "Running ruff check..."
uv run ruff check .

echo "Running ruff format check..."
uv run ruff format --check .

# Test gate — prevents commits that break the suite. Full run is ~80s
# but that's the cost of keeping `uv run pytest` trustworthy as a green
# signal. If this is slow during WIP, commit in smaller diffs — do NOT
# --no-verify around it (see CLAUDE.md testing policy).
echo "Running pytest (may take ~80s)..."
uv run pytest --ignore=output --ignore=website_output -q --tb=no

echo "Pre-commit checks passed."
