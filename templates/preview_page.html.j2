<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <meta name="theme-color" content="#1a1817">
  <title>{{ church_name }} — {{ episode_title }}</title>
  {% if has_logo %}<link rel="icon" href="logo.png">{% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      /* Warm dark editorial palette */
      --color-bg:          #1a1817;
      --color-bg-elev:     #211e1c;
      --color-surface:     #252220;
      --color-surface-2:   #2d2926;
      --color-fg:          #ede4d3;
      --color-fg-soft:     #b8ada0;
      --color-fg-faint:    #80776c;
      --color-accent:      #d4a55c;     /* warm gold */
      --color-accent-2:    #e6b876;
      --color-accent-soft: rgba(212, 165, 92, 0.14);
      --color-border:      rgba(237, 228, 211, 0.09);
      --color-border-hi:   rgba(237, 228, 211, 0.18);

      --font-display: "Fraunces", "Playfair Display", Georgia, serif;
      --font-body:    "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;

      --max-width:     980px;
      --reading-width: 680px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      color: var(--color-fg);
      background: var(--color-bg);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    /* ---------------- AURORA + GRAIN ---------------- */
    .aurora {
      position: fixed;
      inset: 0;
      z-index: -10;
      overflow: hidden;
      pointer-events: none;
    }
    .aurora-blob {
      position: absolute;
      width: 60vw;
      height: 60vw;
      border-radius: 50%;
      filter: blur(110px);
      opacity: 0.55;
      will-change: transform;
    }
    .aurora-blob--1 {
      background: radial-gradient(circle, rgba(168,66,15,0.65) 0%, transparent 65%);
      top: -15%; left: -15%;
      animation: drift1 38s ease-in-out infinite alternate;
    }
    .aurora-blob--2 {
      background: radial-gradient(circle, rgba(212,165,92,0.55) 0%, transparent 65%);
      top: 25%; right: -20%;
      animation: drift2 44s ease-in-out infinite alternate;
    }
    .aurora-blob--3 {
      background: radial-gradient(circle, rgba(120,30,60,0.55) 0%, transparent 65%);
      bottom: -20%; left: 20%;
      animation: drift3 50s ease-in-out infinite alternate;
    }
    .aurora-blob--4 {
      background: radial-gradient(circle, rgba(35,55,85,0.45) 0%, transparent 65%);
      top: 65%; left: -10%;
      animation: drift4 56s ease-in-out infinite alternate;
    }
    @keyframes drift1 {
      from { transform: translate3d(0, 0, 0) scale(1); }
      to   { transform: translate3d(22vw, 18vh, 0) scale(1.2); }
    }
    @keyframes drift2 {
      from { transform: translate3d(0, 0, 0) scale(1.1); }
      to   { transform: translate3d(-18vw, 22vh, 0) scale(0.9); }
    }
    @keyframes drift3 {
      from { transform: translate3d(0, 0, 0) scale(0.9); }
      to   { transform: translate3d(18vw, -22vh, 0) scale(1.2); }
    }
    @keyframes drift4 {
      from { transform: translate3d(0, 0, 0) scale(1); }
      to   { transform: translate3d(-22vw, -18vh, 0) scale(1.15); }
    }
    @media (prefers-reduced-motion: reduce) {
      .aurora-blob { animation: none; }
    }
    .grain {
      position: fixed;
      inset: 0;
      z-index: -5;
      pointer-events: none;
      opacity: 0.05;
      mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    /* ---------------- HERO ---------------- */
    .hero {
      position: relative;
      min-height: 75vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      color: #fff;
      isolation: isolate;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background-size: cover;
      background-position: center;
      filter: blur(34px) brightness(0.55) saturate(1.2);
      transform: scale(1.18);
      z-index: -2;
      opacity: 0.85;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse at center, rgba(26,24,23,0.35) 0%, rgba(26,24,23,0.85) 100%),
        linear-gradient(180deg, transparent 0%, var(--color-bg) 100%);
      z-index: -1;
    }
    .hero-content {
      text-align: center;
      padding: 6rem 1.5rem 5rem;
      max-width: var(--max-width);
    }
    .hero-badge {
      display: inline-block;
      background: rgba(255,255,255,0.06);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.16);
      color: var(--color-fg);
      padding: 0.4rem 1rem;
      border-radius: 999px;
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      font-weight: 600;
      margin-bottom: 2.5rem;
      text-transform: uppercase;
    }
    .hero-logo-wrap {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: #fff;
      padding: 0.85rem 1.3rem;
      border-radius: 14px;
      margin-bottom: 1.8rem;
      box-shadow: 0 14px 40px rgba(0,0,0,0.45);
    }
    .hero-logo-wrap img {
      height: 56px;
      width: auto;
      display: block;
    }
    .hero-eyebrow {
      font-size: 0.8rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-fg-soft);
      font-weight: 500;
      margin-bottom: 1rem;
    }
    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(2.2rem, 5.5vw, 4.4rem);
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -0.025em;
      color: #fff;
      text-wrap: balance;
      max-width: 18ch;
      margin: 0 auto;
      text-shadow: 0 2px 30px rgba(0,0,0,0.4);
    }

    /* ---------------- LAYOUT ---------------- */
    .content {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 1.5rem;
    }
    .section {
      padding: 5rem 0;
      border-bottom: 1px solid var(--color-border);
    }
    .section:last-of-type { border-bottom: none; }
    .section-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .section-eyebrow {
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-accent);
      font-weight: 700;
      margin-bottom: 0.6rem;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3.6vw, 2.4rem);
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -0.015em;
      color: var(--color-fg);
    }

    /* ---------------- CLIPS ---------------- */
    .clips-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
    }
    .clip-card {
      position: relative;
      transition: transform 0.3s cubic-bezier(0.2,0.8,0.2,1);
    }
    .clip-card:hover { transform: translateY(-6px); }
    .clip-number {
      position: absolute;
      top: 0.7rem; left: 0.7rem;
      background: rgba(20,18,16,0.85);
      color: var(--color-accent);
      padding: 0.32rem 0.6rem;
      border-radius: 6px;
      font-family: var(--font-display);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      z-index: 2;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid var(--color-accent-soft);
    }
    .clip-card video {
      width: 100%;
      aspect-ratio: 9 / 16;
      object-fit: cover;
      border-radius: 10px;
      background: #000;
      display: block;
      box-shadow: 0 8px 28px rgba(0,0,0,0.4);
      transition: box-shadow 0.3s ease;
    }
    .clip-card:hover video { box-shadow: 0 16px 44px rgba(0,0,0,0.55); }
    .clip-title {
      font-family: var(--font-display);
      font-size: 1.02rem;
      font-weight: 600;
      line-height: 1.3;
      letter-spacing: -0.005em;
      margin-top: 0.85rem;
      color: var(--color-fg);
    }

    /* ---------------- CHAPTERS ---------------- */
    .chapters-list {
      list-style: none;
      max-width: 640px;
      margin: 0 auto;
    }
    .chapter-item {
      display: flex;
      align-items: baseline;
      gap: 1.5rem;
      padding: 1.1rem 0.5rem;
      border-bottom: 1px solid var(--color-border);
      transition: background 0.2s ease, padding-left 0.2s ease;
      border-radius: 4px;
    }
    .chapter-item:hover {
      background: var(--color-accent-soft);
      padding-left: 1rem;
    }
    .chapter-item:last-child { border-bottom: none; }
    .chapter-time {
      font-family: var(--font-body);
      font-feature-settings: "tnum";
      font-variant-numeric: tabular-nums;
      font-size: 0.85rem;
      color: var(--color-fg-faint);
      min-width: 5em;
      font-weight: 500;
    }
    .chapter-title {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 500;
      color: var(--color-fg);
      letter-spacing: -0.005em;
    }

    /* ---------------- BLOG ---------------- */
    .blog-content {
      max-width: var(--reading-width);
      margin: 0 auto;
      font-family: var(--font-display);
      font-size: 1.12rem;
      line-height: 1.7;
      color: var(--color-fg);
    }
    .blog-content h1, .blog-content h2, .blog-content h3 {
      font-family: var(--font-display);
      font-weight: 600;
      margin: 2rem 0 0.8rem;
      letter-spacing: -0.015em;
      line-height: 1.2;
      color: var(--color-fg);
    }
    .blog-content h1 { font-size: 1.7rem; }
    .blog-content h2 { font-size: 1.4rem; }
    .blog-content h3 { font-size: 1.18rem; }
    .blog-content p { margin: 1rem 0; }
    .blog-content ul, .blog-content ol { padding-left: 1.5rem; margin: 1rem 0; }
    .blog-content li { margin: 0.4rem 0; }
    .blog-content blockquote {
      margin: 1.5rem 0;
      padding-left: 1.2rem;
      border-left: 3px solid var(--color-accent);
      font-style: italic;
      color: var(--color-fg-soft);
    }
    .blog-content strong { font-weight: 700; color: var(--color-fg); }

    /* ---------------- TRANSCRIPT ---------------- */
    .transcript-wrap {
      max-width: var(--reading-width);
      margin: 0 auto;
    }
    .transcript {
      font-family: var(--font-display);
      font-size: 1.04rem;
      line-height: 1.8;
      max-height: 32rem;
      overflow-y: auto;
      padding: 2.2rem 2rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.25);
    }
    .transcript p { margin: 0.5rem 0; color: var(--color-fg); }
    .transcript p:first-of-type::first-letter {
      font-family: var(--font-display);
      font-size: 3.6rem;
      font-weight: 700;
      float: left;
      line-height: 0.85;
      margin: 0.15rem 0.55rem 0 0;
      color: var(--color-accent);
      text-shadow: 0 2px 12px rgba(212,165,92,0.4);
    }
    .transcript .ts {
      display: inline-block;
      font-family: var(--font-body);
      font-size: 0.7rem;
      font-feature-settings: "tnum";
      font-variant-numeric: tabular-nums;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--color-accent);
      background: var(--color-accent-soft);
      padding: 0.18rem 0.55rem;
      border-radius: 4px;
      margin-right: 0.55em;
      vertical-align: 0.1em;
      user-select: none;
      border: 1px solid rgba(212,165,92,0.18);
    }
    .transcript::-webkit-scrollbar { width: 8px; }
    .transcript::-webkit-scrollbar-track { background: transparent; }
    .transcript::-webkit-scrollbar-thumb {
      background: rgba(237,228,211,0.12);
      border-radius: 4px;
    }
    .transcript::-webkit-scrollbar-thumb:hover { background: rgba(237,228,211,0.25); }

    /* ---------------- CTA ---------------- */
    .cta {
      margin: 5rem 0;
      padding: 4.5rem 2rem;
      background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-surface-2) 100%);
      color: var(--color-fg);
      border-radius: 16px;
      text-align: center;
      position: relative;
      overflow: hidden;
      border: 1px solid var(--color-border-hi);
      box-shadow: 0 16px 50px rgba(0,0,0,0.4);
    }
    .cta::before {
      content: "";
      position: absolute;
      top: -60%; right: -25%;
      width: 70%; height: 220%;
      background: radial-gradient(ellipse at center, var(--color-accent) 0%, transparent 60%);
      opacity: 0.16;
      pointer-events: none;
    }
    .cta::after {
      content: "";
      position: absolute;
      bottom: -50%; left: -20%;
      width: 60%; height: 180%;
      background: radial-gradient(ellipse at center, rgba(168,66,15,0.8) 0%, transparent 60%);
      opacity: 0.12;
      pointer-events: none;
    }
    .cta-eyebrow {
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-fg-soft);
      font-weight: 700;
      margin-bottom: 1rem;
      position: relative;
    }
    .cta-title {
      font-family: var(--font-display);
      font-size: clamp(1.9rem, 4vw, 2.6rem);
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
      color: var(--color-fg);
      max-width: 22ch;
      margin-left: auto;
      margin-right: auto;
      position: relative;
    }
    .cta-body {
      font-size: 1.05rem;
      color: var(--color-fg-soft);
      margin-bottom: 2.2rem;
      position: relative;
    }
    .cta-button {
      display: inline-block;
      background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-2) 100%);
      color: #1a1817;
      padding: 1rem 2.2rem;
      border-radius: 999px;
      font-weight: 700;
      font-size: 1rem;
      text-decoration: none;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      letter-spacing: 0.005em;
      box-shadow: 0 6px 24px rgba(212,165,92,0.35);
      position: relative;
    }
    .cta-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(212,165,92,0.5);
    }
    .cta-note {
      margin-top: 2rem;
      font-size: 0.85rem;
      color: var(--color-fg-faint);
      font-style: italic;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.5;
      position: relative;
    }

    /* ---------------- RESPONSIVE ---------------- */
    @media (max-width: 720px) {
      .section { padding: 3.5rem 0; }
      .hero-content { padding: 4rem 1rem 3rem; }
      .hero-logo-wrap img { height: 48px; }
      .clips-row { grid-template-columns: 1fr 1fr; gap: 1rem; }
      .transcript { padding: 1.5rem 1.2rem; }
      .cta { padding: 3rem 1.5rem; margin: 2.5rem 0; }
    }
    @media (max-width: 420px) {
      .clips-row { grid-template-columns: 1fr; }
      .chapter-item { gap: 1rem; padding: 0.9rem 0.3rem; }
    }
  </style>
</head>
<body>

  <div class="aurora">
    <div class="aurora-blob aurora-blob--1"></div>
    <div class="aurora-blob aurora-blob--2"></div>
    <div class="aurora-blob aurora-blob--3"></div>
    <div class="aurora-blob aurora-blob--4"></div>
  </div>
  <div class="grain"></div>

  <section class="hero">
    {% if has_thumbnail %}<div class="hero-bg" style="background-image: url('thumbnail.png')"></div>{% endif %}
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-badge">Preview</div>
      {% if has_logo %}
      <div class="hero-logo-wrap">
        <img src="logo.png" alt="{{ church_name }} logo">
      </div>
      {% endif %}
      <p class="hero-eyebrow">{{ church_name }}</p>
      <h1 class="hero-title">{{ episode_title }}</h1>
    </div>
  </section>

  <main class="content">

    {% if clips %}
    <section class="section">
      <div class="section-header">
        <p class="section-eyebrow">Highlights</p>
        <h2 class="section-title">Clips from this sermon</h2>
      </div>
      <div class="clips-row">
        {% for clip in clips %}
        <article class="clip-card">
          <div class="clip-number">{{ "%02d"|format(loop.index) }}</div>
          <video controls preload="none" src="{{ clip.filename }}"{% if has_thumbnail %} poster="thumbnail.png"{% endif %}></video>
          <h3 class="clip-title">{{ clip.title }}</h3>
        </article>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {% if chapters %}
    <section class="section">
      <div class="section-header">
        <p class="section-eyebrow">Navigate</p>
        <h2 class="section-title">Chapters</h2>
      </div>
      <ol class="chapters-list">
        {% for ch in chapters %}
        <li class="chapter-item">
          <span class="chapter-time">{{ ch.timestamp }}</span>
          <span class="chapter-title">{{ ch.title }}</span>
        </li>
        {% endfor %}
      </ol>
    </section>
    {% endif %}

    {% if blog_html %}
    <section class="section">
      <div class="section-header">
        <p class="section-eyebrow">Devotional</p>
        <h2 class="section-title">Reflections from the message</h2>
      </div>
      <article class="blog-content">{{ blog_html|safe }}</article>
    </section>
    {% endif %}

    {% if transcript_segments %}
    <section class="section">
      <div class="section-header">
        <p class="section-eyebrow">Reading</p>
        <h2 class="section-title">Full transcript</h2>
      </div>
      <div class="transcript-wrap">
        <div class="transcript">
          {% for seg in transcript_segments %}
          <p><span class="ts">{{ seg.timestamp }}</span>{{ seg.text }}</p>
          {% endfor %}
        </div>
      </div>
    </section>
    {% endif %}

    <section class="cta">
      <p class="cta-eyebrow">Built for {{ church_name }}</p>
      <h2 class="cta-title">Want this for every sermon?</h2>
      <p class="cta-body">Generated by Evan @ Neurova. One sermon in, fifteen-plus content pieces out — every week, automatically.</p>
      <a href="mailto:evan@neurovai.org" class="cta-button">evan@neurovai.org</a>
      <p class="cta-note">Live page would live on yoursite.com — Google indexes long-form sermon transcripts and drives roughly 7&times; more organic traffic than audio-only pages.</p>
    </section>

  </main>
</body>
</html>
